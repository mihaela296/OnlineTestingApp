<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OnlineTestingApp.Views.PendingApprovalPage"
             NavigationPage.HasNavigationBar="False">
    
    <Grid>
        <Grid Background="{StaticResource BackgroundGradient}"/>
        
        <Ellipse Fill="#2DD4BF08" WidthRequest="500" HeightRequest="500" HorizontalOptions="Center" VerticalOptions="Center"/>
        
        <ScrollView>
            <VerticalStackLayout Spacing="20" VerticalOptions="Center">
                
                <Frame Padding="0" Margin="0" HasShadow="False" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="20" HorizontalOptions="Center" WidthRequest="450">
                        
                        <Frame WidthRequest="100"
                               HeightRequest="100"
                               CornerRadius="50"
                               Background="{StaticResource PrimaryGradient}"
                               HasShadow="False"
                               HorizontalOptions="Center"
                               Margin="0,0,0,20">
                            <Label Text="👨‍🏫" 
                                   FontSize="48" 
                                   TextColor="White"
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center"/>
                        </Frame>
                        
                        <Label Text="Ожидание подтверждения" 
                               Style="{StaticResource TitleStyle}"
                               Margin="0,0,0,4"/>
                        
                        <Label Text="Ваша заявка отправлена!"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               Margin="0,0,0,8"/>
                        
                        <Label Text="Ожидайте подтверждения администратором."
                               Style="{StaticResource SubtitleStyle}"/>

                        <Button Text="Выйти из аккаунта"
                                x:Name="LogoutButton"
                                Style="{StaticResource ErrorButtonStyle}"
                                WidthRequest="200"
                                HorizontalOptions="Center"
                                Margin="0,32,0,0"/>
                        
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>