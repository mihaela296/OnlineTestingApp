<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OnlineTestingApp.Converters"
             x:Class="OnlineTestingApp.Views.Auth.ResetPasswordPage"
             NavigationPage.HasNavigationBar="False">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <Grid Background="{StaticResource BackgroundGradient}"/>
        
        <Ellipse Fill="#2DD4BF08" WidthRequest="500" HeightRequest="500" HorizontalOptions="Start" VerticalOptions="Start" Margin="-200,-150,0,0"/>
        <Ellipse Fill="#14B8A610" WidthRequest="400" HeightRequest="400" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,-150,-100"/>
        
        <ScrollView>
            <VerticalStackLayout Spacing="20" VerticalOptions="Center">
                
                <Frame Padding="0" Margin="0" HasShadow="False" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="20" HorizontalOptions="Center" WidthRequest="450">
                        
                        <Frame WidthRequest="80"
                               HeightRequest="80"
                               CornerRadius="40"
                               Background="{StaticResource PrimaryGradient}"
                               HasShadow="False"
                               HorizontalOptions="Center"
                               Margin="0,0,0,20">
                            <Label Text="🔑" 
                                   FontSize="40" 
                                   TextColor="White"
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center"/>
                        </Frame>
                        
                        <Label Text="Новый пароль" 
                               Style="{StaticResource TitleStyle}"
                               Margin="0,0,0,4"/>
                        
                        <Label Text="Придумайте новый пароль"
                               Style="{StaticResource SubtitleStyle}"
                               Margin="0,0,0,32"/>

                        <!-- Новый пароль -->
                        <Border Style="{StaticResource EntryStyle}">
                            <Grid ColumnDefinitions="*, Auto">
                                <Entry x:Name="NewPasswordEntry"
                                       Grid.Column="0"
                                       Text="{Binding NewPassword}"
                                       Placeholder="Новый пароль"
                                       IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                                       BackgroundColor="Transparent"/>
                                <Button Grid.Column="1"
                                        Command="{Binding TogglePasswordVisibilityCommand}"
                                        BackgroundColor="Transparent"
                                        Text="👁"
                                        FontSize="18"
                                        TextColor="{StaticResource Primary}"
                                        WidthRequest="40"
                                        Padding="0"/>
                            </Grid>
                        </Border>

                        <!-- Подтверждение пароля -->
                        <Border Style="{StaticResource EntryStyle}">
                            <Grid ColumnDefinitions="*, Auto">
                                <Entry x:Name="ConfirmPasswordEntry"
                                       Grid.Column="0"
                                       Text="{Binding ConfirmPassword}"
                                       Placeholder="Подтвердите пароль"
                                       IsPassword="{Binding IsConfirmPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                                       BackgroundColor="Transparent"/>
                                <Button Grid.Column="1"
                                        Command="{Binding ToggleConfirmPasswordVisibilityCommand}"
                                        BackgroundColor="Transparent"
                                        Text="👁"
                                        FontSize="18"
                                        TextColor="{StaticResource Primary}"
                                        WidthRequest="40"
                                        Padding="0"/>
                            </Grid>
                        </Border>

                        <Border IsVisible="{Binding HasError}"
                                BackgroundColor="{StaticResource ErrorLightBg}"
                                Padding="12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                Margin="0,4">
                            <Label Text="{Binding Message}"
                                   TextColor="{StaticResource Error}"
                                   FontSize="13"
                                   HorizontalOptions="Center"/>
                        </Border>

                        <Border IsVisible="{Binding IsSuccess}"
                                BackgroundColor="{StaticResource SuccessLightBg}"
                                Padding="12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                Margin="0,4">
                            <Label Text="{Binding Message}"
                                   TextColor="{StaticResource Success}"
                                   FontSize="13"
                                   HorizontalOptions="Center"/>
                        </Border>

                        <Button Text="Сбросить пароль"
                                Command="{Binding ResetPasswordCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                WidthRequest="200"
                                HorizontalOptions="Center"
                                Margin="0,8,0,0"/>
                        
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>