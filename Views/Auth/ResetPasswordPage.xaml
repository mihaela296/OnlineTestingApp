<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OnlineTestingApp.Converters"
             x:Class="OnlineTestingApp.Views.Auth.ResetPasswordPage"
             Title="Новый пароль"
             BackgroundColor="White">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">
            
            <Label Text="🔑" FontSize="72" HorizontalOptions="Center" Margin="0,0,0,10"/>
            <Label Text="Новый пароль" FontSize="28" TextColor="#111827" FontAttributes="Bold" HorizontalOptions="Center"/>
            <Label Text="Придумайте новый пароль" FontSize="14" TextColor="#4B5563" HorizontalTextAlignment="Center" Margin="0,0,0,20"/>

            <Label Text="Новый пароль *" TextColor="#374151" FontSize="13" Margin="0,0,0,2"/>
            <Grid ColumnDefinitions="*, 50" Margin="0,0,0,15">
                <Entry x:Name="NewPasswordEntry" Grid.Column="0" Text="{Binding NewPassword}" Placeholder="Минимум 6 символов" BackgroundColor="#F3F4F6" TextColor="#111827" PlaceholderColor="#9CA3AF" IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolConverter}}" FontSize="15" HeightRequest="48"/>
                <Button Grid.Column="1" Command="{Binding TogglePasswordVisibilityCommand}" BackgroundColor="Transparent" Text="👁️" FontSize="24" TextColor="#6366F1" HeightRequest="48" WidthRequest="50" Padding="0"/>
            </Grid>

            <Label Text="Подтвердите пароль *" TextColor="#374151" FontSize="13" Margin="0,0,0,2"/>
            <Grid ColumnDefinitions="*, 50" Margin="0,0,0,15">
                <Entry x:Name="ConfirmPasswordEntry" Grid.Column="0" Text="{Binding ConfirmPassword}" Placeholder="Повторите пароль" BackgroundColor="#F3F4F6" TextColor="#111827" PlaceholderColor="#9CA3AF" IsPassword="{Binding IsConfirmPasswordVisible, Converter={StaticResource InverseBoolConverter}}" FontSize="15" HeightRequest="48"/>
                <Button Grid.Column="1" Command="{Binding ToggleConfirmPasswordVisibilityCommand}" BackgroundColor="Transparent" Text="👁️" FontSize="24" TextColor="#6366F1" HeightRequest="48" WidthRequest="50" Padding="0"/>
            </Grid>

            <Label IsVisible="{Binding HasError}" Text="{Binding Message}" TextColor="Red" FontSize="14" HorizontalOptions="Center" Margin="0,0,0,10"/>
            <Label IsVisible="{Binding IsSuccess}" Text="{Binding Message}" TextColor="Green" FontSize="14" HorizontalOptions="Center" Margin="0,0,0,10"/>

            <Button Text="Сбросить пароль" Command="{Binding ResetPasswordCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" BackgroundColor="#10B981" TextColor="White" FontSize="15" FontAttributes="Bold" HeightRequest="48" CornerRadius="24" Margin="0,10,0,0"/>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
