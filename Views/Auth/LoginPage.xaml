<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OnlineTestingApp.Converters"
             x:Class="OnlineTestingApp.Views.Auth.LoginPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">
            
            <!-- Заголовок -->
            <Label Text="Добро пожаловать!" 
                   FontSize="32"
                   TextColor="#111827"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>
            
            <Label Text="Войдите, чтобы продолжить"
                   FontSize="16"
                   TextColor="#4B5563"
                   HorizontalOptions="Center"
                   Margin="0,0,0,30"/>

            <!-- Email -->
            <Label Text="Email"
                   TextColor="#374151"
                   FontSize="14"
                   Margin="0,0,0,4"/>
            
            <Entry Text="{Binding LoginModel.Email}"
                   Placeholder="Введите ваш email"
                   BackgroundColor="#F3F4F6"
                   TextColor="#111827"
                   PlaceholderColor="#9CA3AF"
                   FontSize="16"
                   HeightRequest="56"
                   Margin="0,0,0,16"/>

            <!-- Пароль -->
            <Label Text="Пароль"
                   TextColor="#374151"
                   FontSize="14"
                   Margin="0,0,0,4"/>
            
            <Entry Text="{Binding LoginModel.Password}"
                   Placeholder="Введите пароль"
                   BackgroundColor="#F3F4F6"
                   TextColor="#111827"
                   PlaceholderColor="#9CA3AF"
                   IsPassword="True"
                   FontSize="16"
                   HeightRequest="56"
                   Margin="0,0,0,16"/>

            <!-- Запомнить меня и забыли пароль -->
            <Grid ColumnDefinitions="*,*" Margin="0,0,0,20">
                <HorizontalStackLayout Grid.Column="0" Spacing="8">
                    <CheckBox IsChecked="{Binding LoginModel.RememberMe}"
                             Color="#6366F1"/>
                    <Label Text="Запомнить меня"
                           VerticalOptions="Center"
                           TextColor="#4B5563"/>
                </HorizontalStackLayout>
                
                <Label Grid.Column="1"
                       Text="Забыли пароль?"
                       TextColor="#6366F1"
                       HorizontalOptions="End"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnForgotPasswordTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <!-- Сообщение об ошибке -->
            <Border x:Name="ErrorFrame"
                   IsVisible="{Binding HasError}"
                   BackgroundColor="#EF4444"
                   Padding="12"
                   StrokeThickness="0"
                   Margin="0,0,0,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Label Text="{Binding ErrorMessage}"
                       TextColor="White"
                       FontSize="14"
                       HorizontalOptions="Center"/>
            </Border>

            <!-- Кнопка входа -->
            <Button Text="Войти"
                    Command="{Binding LoginCommand}"
                    BackgroundColor="#6366F1"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    HeightRequest="56"
                    CornerRadius="28"
                    Margin="0,0,0,16"/>

            <!-- Разделитель -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,0,0,16">
                <BoxView HeightRequest="1" 
                        WidthRequest="100" 
                        Color="#9CA3AF"
                        Opacity="0.3"
                        VerticalOptions="Center"/>
                <Label Text="или" 
                       TextColor="#9CA3AF"/>
                <BoxView HeightRequest="1" 
                        WidthRequest="100" 
                        Color="#9CA3AF"
                        Opacity="0.3"
                        VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Кнопка регистрации - ИСПРАВЛЕНО -->
            <Button Text="Создать аккаунт"
                    Command="{Binding GoToRegisterCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#6366F1"
                    FontSize="16"
                    HeightRequest="56"
                    CornerRadius="28"
                    BorderColor="#6366F1"
                    BorderWidth="2"/>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
