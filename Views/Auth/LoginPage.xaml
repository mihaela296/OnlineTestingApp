<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OnlineTestingApp.Converters"
             x:Class="OnlineTestingApp.Views.Auth.LoginPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Background}">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:IsEqualConverter x:Key="IsEqualConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <!-- Фоновый градиент -->
        <Grid Background="{StaticResource SurfaceGradient}"/>
        
        <!-- Основной контент -->
        <ScrollView>
            <VerticalStackLayout Spacing="24" Padding="24" VerticalOptions="Center">
                
                <!-- Логотип и заголовок -->
                <VerticalStackLayout Spacing="8" Margin="0,40,0,40">
                    <Image Source="logo.png" 
                           HeightRequest="80" 
                           WidthRequest="80"
                           HorizontalOptions="Center"/>
                    
                    <Label Text="Добро пожаловать!" 
                           Style="{StaticResource TitleStyle}"/>
                    
                    <Label Text="Войдите, чтобы продолжить"
                           Style="{StaticResource SubtitleStyle}"/>
                </VerticalStackLayout>

                <!-- Карточка с формой -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="20">
                        
                        <!-- Email -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Email"
                                   FontSize="14"
                                   TextColor="{StaticResource TextSecondary}"/>
                            
                            <Entry x:Name="EmailEntry"
                                   Text="{Binding LoginModel.Email}"
                                   Placeholder="Введите ваш email"
                                   Style="{StaticResource ModernEntry}"
                                   Keyboard="Email"
                                   ReturnType="Next"/>
                        </VerticalStackLayout>

                        <!-- Пароль -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Пароль"
                                   FontSize="14"
                                   TextColor="{StaticResource TextSecondary}"/>
                            
                            <Entry x:Name="PasswordEntry"
                                   Text="{Binding LoginModel.Password}"
                                   Placeholder="Введите пароль"
                                   Style="{StaticResource ModernEntry}"
                                   IsPassword="True"
                                   ReturnType="Done"/>
                        </VerticalStackLayout>

                        <!-- Запомнить меня и забыли пароль -->
                        <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
                            <HorizontalStackLayout Grid.Column="0" Spacing="8">
                                <CheckBox IsChecked="{Binding LoginModel.RememberMe}"
                                         Color="{StaticResource Primary}"/>
                                <Label Text="Запомнить меня"
                                       VerticalOptions="Center"
                                       TextColor="{StaticResource TextSecondary}"/>
                            </HorizontalStackLayout>
                            
                            <Label Grid.Column="1"
                                   Text="Забыли пароль?"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="End"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnForgotPasswordTapped"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <!-- Сообщение об ошибке - ЗАМЕНИЛ FRAME НА BORDER -->
                        <Border x:Name="ErrorFrame"
                               IsVisible="{Binding HasError}"
                               BackgroundColor="{StaticResource Error}"
                               Padding="12"
                               StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding ErrorMessage}"
                                   TextColor="White"
                                   FontSize="14"/>
                        </Border>

                        <!-- Кнопка входа -->
                        <Button Text="Войти"
                                Command="{Binding LoginCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                Style="{StaticResource PrimaryButtonStyle}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" 
                                            Binding="{Binding IsBusy}" 
                                            Value="True">
                                    <Setter Property="Text" Value="Вход..."/>
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <!-- Разделитель -->
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                            <BoxView HeightRequest="1" 
                                    WidthRequest="100" 
                                    Color="{StaticResource TextLight}"
                                    VerticalOptions="Center"/>
                            <Label Text="или" 
                                   TextColor="{StaticResource TextLight}"/>
                            <BoxView HeightRequest="1" 
                                    WidthRequest="100" 
                                    Color="{StaticResource TextLight}"
                                    VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Кнопка регистрации -->
                        <Button Text="Создать аккаунт"
                                Command="{Binding NavigateToRegisterCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Индикатор загрузки -->
                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                  IsRunning="{Binding IsBusy}"
                                  Style="{StaticResource ModernActivityIndicator}"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>