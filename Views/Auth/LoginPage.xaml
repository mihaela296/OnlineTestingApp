<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OnlineTestingApp.Converters"
             x:Class="OnlineTestingApp.Views.Auth.LoginPage"
             NavigationPage.HasNavigationBar="False">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <Grid Background="{StaticResource BackgroundGradient}"/>
        
        <!-- Декоративные круги -->
        <Ellipse Fill="#2DD4BF08"
                 WidthRequest="550"
                 HeightRequest="550"
                 HorizontalOptions="Start"
                 VerticalOptions="Start"
                 Margin="-250,-200,0,0"/>
        
        <Ellipse Fill="#2DD4BF12"
                 WidthRequest="450"
                 HeightRequest="450"
                 HorizontalOptions="End"
                 VerticalOptions="Center"
                 Margin="0,0,-200,50"/>
        
        <Ellipse Fill="#14B8A610"
                 WidthRequest="350"
                 HeightRequest="350"
                 HorizontalOptions="Center"
                 VerticalOptions="End"
                 Margin="0,0,0,-150"/>
        
        <Ellipse Fill="#5EEAD408"
                 WidthRequest="300"
                 HeightRequest="300"
                 HorizontalOptions="Start"
                 VerticalOptions="End"
                 Margin="-100,0,0,-100"/>
        
        <ScrollView>
            <VerticalStackLayout Spacing="20" VerticalOptions="Center">
                
                <Frame Padding="0" Margin="0" HasShadow="False" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="20" HorizontalOptions="Center" WidthRequest="450">
                        
                        <!-- Логотип -->
                        <Frame WidthRequest="80"
                               HeightRequest="80"
                               CornerRadius="40"
                               Background="{StaticResource PrimaryGradient}"
                               HasShadow="False"
                               HorizontalOptions="Center"
                               Margin="0,0,0,20">
                            <Label Text="T" 
                                   FontSize="40" 
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center"/>
                        </Frame>
                        
                        <Label Text="Добро пожаловать!" 
                               Style="{StaticResource TitleStyle}"
                               Margin="0,0,0,4"/>
                        
                        <Label Text="Войдите, чтобы продолжить"
                               Style="{StaticResource SubtitleStyle}"
                               Margin="0,0,0,32"/>

                        <!-- Email поле -->
                        <Border Style="{StaticResource EntryStyle}">
                            <Entry Text="{Binding LoginModel.Email}"
                                   Placeholder="Email"
                                   Keyboard="Email"
                                   BackgroundColor="Transparent"/>
                        </Border>

                        <!-- Пароль поле -->
                        <Border Style="{StaticResource EntryStyle}">
                            <Grid ColumnDefinitions="*, Auto">
                                <Entry x:Name="PasswordEntry"
                                       Grid.Column="0"
                                       Text="{Binding LoginModel.Password}"
                                       Placeholder="Пароль"
                                       IsPassword="True"
                                       BackgroundColor="Transparent"/>
                                <Button Grid.Column="1"
                                        Clicked="OnTogglePasswordClicked"
                                        BackgroundColor="Transparent"
                                        Text="👁"
                                        FontSize="18"
                                        TextColor="{StaticResource Primary}"
                                        WidthRequest="40"
                                        Padding="0"/>
                            </Grid>
                        </Border>

                        <!-- Запомнить меня и забыли пароль -->
                        <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                            <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                                <CheckBox IsChecked="{Binding LoginModel.RememberMe}"
                                         Color="{StaticResource Primary}"
                                         HeightRequest="18"
                                         WidthRequest="18"
                                         VerticalOptions="Center"/>
                                <Label Text="Запомнить меня"
                                       TextColor="{StaticResource TextSecondary}"
                                       FontSize="13"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            
                            <Button Grid.Column="1"
                                    Text="Забыли пароль?"
                                    Command="{Binding ForgotPasswordCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource Primary}"
                                    FontSize="13"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <Border IsVisible="{Binding HasError}"
                                BackgroundColor="{StaticResource ErrorLightBg}"
                                Padding="12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                Margin="0,8">
                            <Label Text="{Binding ErrorMessage}"
                                   TextColor="{StaticResource Error}"
                                   FontSize="13"
                                   HorizontalOptions="Center"/>
                        </Border>

                       <!-- Кнопка Войти - без имени -->
<Button Text="Войти"
        Command="{Binding LoginCommand}"
        Style="{StaticResource PrimaryButtonStyle}"
        WidthRequest="200"
        HorizontalOptions="Center"
        Margin="0,8,0,0"/>

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="12" Margin="0,16">
                            <BoxView HeightRequest="1" WidthRequest="60" Color="#2DD4BF30" VerticalOptions="Center"/>
                            <Label Text="или" TextColor="{StaticResource TextMuted}" FontSize="13"/>
                            <BoxView HeightRequest="1" WidthRequest="60" Color="#2DD4BF30" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Button Text="Создать аккаунт"
                                Command="{Binding GoToRegisterCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                WidthRequest="200"
                                HorizontalOptions="Center"
                                Margin="0,0,0,8"/>
                        
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>