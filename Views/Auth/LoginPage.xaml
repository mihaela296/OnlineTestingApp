<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OnlineTestingApp.Converters"
             x:Class="OnlineTestingApp.Views.Auth.LoginPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="30" VerticalOptions="Center">
            
            <!-- Заголовок -->
            <Label Text="Добро пожаловать!" 
                   FontSize="28"
                   TextColor="#111827"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,4"/>
            
            <Label Text="Войдите, чтобы продолжить"
                   FontSize="14"
                   TextColor="#4B5563"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>

            <!-- Email -->
            <Label Text="Email"
                   TextColor="#374151"
                   FontSize="13"
                   Margin="0,0,0,2"/>
            
            <Entry Text="{Binding LoginModel.Email}"
                   Placeholder="email@example.com"
                   BackgroundColor="#F3F4F6"
                   TextColor="#111827"
                   PlaceholderColor="#9CA3AF"
                   FontSize="15"
                   HeightRequest="48"
                   Margin="0,0,0,12"/>

            <!-- Пароль с глазиком -->
            <Label Text="Пароль"
                   TextColor="#374151"
                   FontSize="13"
                   Margin="0,0,0,2"/>
            
            <Grid ColumnDefinitions="*, 50" Margin="0,0,0,12">
                <Entry x:Name="PasswordEntry"
                       Grid.Column="0"
                       Text="{Binding LoginModel.Password}"
                       Placeholder="••••••••"
                       BackgroundColor="#F3F4F6"
                       TextColor="#111827"
                       PlaceholderColor="#9CA3AF"
                       IsPassword="True"
                       FontSize="15"
                       HeightRequest="48"/>
                
                <Button x:Name="TogglePasswordButton"
                        Grid.Column="1"
                        Clicked="OnTogglePasswordClicked"
                        BackgroundColor="Transparent"
                        Text="👁️"
                        FontSize="24"
                        TextColor="#6366F1"
                        HeightRequest="48"
                        WidthRequest="50"
                        Padding="0"/>
            </Grid>

            <!-- Запомнить меня и забыли пароль -->
            <Grid ColumnDefinitions="*,*" Margin="0,0,0,20">
                <HorizontalStackLayout Grid.Column="0" Spacing="6">
                    <CheckBox IsChecked="{Binding LoginModel.RememberMe}"
                             Color="#6366F1"
                             HeightRequest="18"
                             WidthRequest="18"/>
                    <Label Text="Запомнить меня"
                           VerticalOptions="Center"
                           TextColor="#4B5563"
                           FontSize="13"/>
                </HorizontalStackLayout>
                
                <Label Grid.Column="1"
                       Text="Забыли пароль?"
                       TextColor="#6366F1"
                       FontSize="13"
                       HorizontalOptions="End"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnForgotPasswordTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>

            <!-- Сообщение об ошибке -->
            <Border x:Name="ErrorFrame"
                   IsVisible="{Binding HasError}"
                   BackgroundColor="#FEE2E2"
                   Padding="10"
                   StrokeThickness="0"
                   Margin="0,0,0,12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#DC2626"
                       FontSize="13"
                       HorizontalOptions="Center"/>
            </Border>

            <!-- Кнопка входа - УМЕНЬШЕНА И ОТЦЕНТРИРОВАНА -->
            <Button Text="Войти"
                    Command="{Binding LoginCommand}"
                    BackgroundColor="#6366F1"
                    TextColor="White"
                    FontSize="15"
                    FontAttributes="Bold"
                    HeightRequest="48"
                    WidthRequest="200"
                    HorizontalOptions="Center"
                    CornerRadius="24"
                    Margin="0,0,0,12"/>

            <!-- Разделитель -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,4">
                <BoxView HeightRequest="1" 
                        WidthRequest="80" 
                        Color="#E5E7EB"
                        VerticalOptions="Center"/>
                <Label Text="или" 
                       TextColor="#9CA3AF"
                       FontSize="13"/>
                <BoxView HeightRequest="1" 
                        WidthRequest="80" 
                        Color="#E5E7EB"
                        VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Кнопка регистрации - УМЕНЬШЕНА И ОТЦЕНТРИРОВАНА -->
            <Button Text="Создать аккаунт"
                    Command="{Binding GoToRegisterCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#6366F1"
                    BorderColor="#6366F1"
                    BorderWidth="1.5"
                    FontSize="15"
                    HeightRequest="48"
                    WidthRequest="200"
                    HorizontalOptions="Center"
                    CornerRadius="24"
                    Margin="0,0,0,0"/>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
