<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OnlineTestingApp.Converters"
             x:Class="OnlineTestingApp.Views.Auth.VerifyCodePage"
             NavigationPage.HasNavigationBar="False">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <Grid Background="{StaticResource BackgroundGradient}"/>
        
        <Ellipse Fill="#2DD4BF08" WidthRequest="500" HeightRequest="500" HorizontalOptions="End" VerticalOptions="Start" Margin="0,-200,-150,0"/>
        <Ellipse Fill="#14B8A610" WidthRequest="400" HeightRequest="400" HorizontalOptions="Start" VerticalOptions="End" Margin="-150,0,0,-100"/>
        
        <ScrollView>
            <VerticalStackLayout Spacing="20" VerticalOptions="Center">
                
                <Frame Padding="0" Margin="0" HasShadow="False" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="20" HorizontalOptions="Center" WidthRequest="450">
                        
                        <Frame WidthRequest="80"
                               HeightRequest="80"
                               CornerRadius="40"
                               Background="{StaticResource PrimaryGradient}"
                               HasShadow="False"
                               HorizontalOptions="Center"
                               Margin="0,0,0,20">
                            <Label Text="✉️" 
                                   FontSize="40" 
                                   TextColor="White"
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center"/>
                        </Frame>
                        
                        <Label Text="Проверьте почту" 
                               Style="{StaticResource TitleStyle}"
                               Margin="0,0,0,4"/>
                        
                        <Label Text="Мы отправили 6-значный код на"
                               Style="{StaticResource SubtitleStyle}"/>
                        
                        <Label Text="{Binding Email}"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               Margin="0,0,0,24"/>

                        <!-- Код поле -->
                        <Border Style="{StaticResource EntryStyle}">
                            <Entry Text="{Binding Code}"
                                   Placeholder="XXXXXX"
                                   Keyboard="Numeric"
                                   MaxLength="6"
                                   HorizontalTextAlignment="Center"
                                   FontSize="20"
                                   BackgroundColor="Transparent"/>
                        </Border>

                        <Border IsVisible="{Binding HasError}"
                                BackgroundColor="{StaticResource ErrorLightBg}"
                                Padding="12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                Margin="0,4">
                            <Label Text="{Binding Message}"
                                   TextColor="{StaticResource Error}"
                                   FontSize="13"
                                   HorizontalOptions="Center"/>
                        </Border>

                        <Button Text="Подтвердить код"
                                Command="{Binding VerifyCodeCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                WidthRequest="200"
                                HorizontalOptions="Center"
                                Margin="0,8,0,0"/>

                        <Button Text="← Вернуться"
                                Command="{Binding GoBackCommand}"
                                Style="{StaticResource GlassButtonStyle}"
                                WidthRequest="200"
                                HorizontalOptions="Center"
                                Margin="0,8,0,0"/>
                        
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>