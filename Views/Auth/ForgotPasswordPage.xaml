<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OnlineTestingApp.Converters"
             x:Class="OnlineTestingApp.Views.Auth.ForgotPasswordPage"
             NavigationPage.HasNavigationBar="False">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <Grid Background="{StaticResource BackgroundGradient}"/>
        
        <!-- Декоративные круги -->
        <Ellipse Fill="#2DD4BF08" WidthRequest="500" HeightRequest="500" HorizontalOptions="Start" VerticalOptions="Start" Margin="-200,-150,0,0"/>
        <Ellipse Fill="#14B8A610" WidthRequest="400" HeightRequest="400" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,-150,-100"/>
        
        <ScrollView>
            <VerticalStackLayout Spacing="20" VerticalOptions="Center">
                
                <Frame Padding="0" Margin="0" HasShadow="False" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="20" HorizontalOptions="Center" WidthRequest="450">
                        
                        <!-- Иконка -->
                        <Frame WidthRequest="80"
                               HeightRequest="80"
                               CornerRadius="40"
                               Background="{StaticResource PrimaryGradient}"
                               HasShadow="False"
                               HorizontalOptions="Center"
                               Margin="0,0,0,20">
                            <Label Text="🔐" 
                                   FontSize="40" 
                                   TextColor="White"
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center"/>
                        </Frame>
                        
                        <Label Text="Восстановление пароля" 
                               Style="{StaticResource TitleStyle}"
                               Margin="0,0,0,4"/>
                        
                        <Label Text="Введите ваш email, и мы отправим код для сброса пароля"
                               Style="{StaticResource SubtitleStyle}"
                               Margin="0,0,0,32"/>

                        <!-- Email поле -->
                        <Border Style="{StaticResource EntryStyle}">
                            <Entry Text="{Binding Email}"
                                   Placeholder="Email"
                                   Keyboard="Email"
                                   BackgroundColor="Transparent"/>
                        </Border>

                        <!-- Сообщение -->
                        <Border IsVisible="{Binding HasMessage}"
                                BackgroundColor="{Binding IsSuccess, Converter={StaticResource BoolToColorConverter}, ConverterParameter=#10B98120:#EF444420}"
                                Padding="12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                Margin="0,4">
                            <Label Text="{Binding Message}"
                                   TextColor="{Binding IsSuccess, Converter={StaticResource BoolToColorConverter}, ConverterParameter=#10B981:#EF4444}"
                                   FontSize="13"
                                   HorizontalOptions="Center"/>
                        </Border>

                        <Button Text="Отправить код"
                                Command="{Binding SendResetCodeCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                WidthRequest="200"
                                HorizontalOptions="Center"
                                Margin="0,8,0,0"/>

                        <Button Text="← Вернуться ко входу"
                                Command="{Binding GoBackCommand}"
                                Style="{StaticResource GlassButtonStyle}"
                                WidthRequest="200"
                                HorizontalOptions="Center"
                                Margin="0,8,0,0"/>
                        
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>