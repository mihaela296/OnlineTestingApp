<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OnlineTestingApp.Converters"
             x:Class="OnlineTestingApp.Views.Auth.ForgotPasswordPage"
             Title="Восстановление пароля"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto,*">

        <!-- Основное содержимое -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">
                
                <Label Text="🔐" FontSize="72" HorizontalOptions="Center" Margin="0,0,0,10"/>
                <Label Text="Забыли пароль?" FontSize="28" TextColor="#111827" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Text="Введите ваш email, и мы отправим код для сброса пароля" FontSize="14" TextColor="#4B5563" HorizontalTextAlignment="Center" Margin="0,0,0,20"/>

                <Label Text="Email" TextColor="#374151" FontSize="13" Margin="0,0,0,2"/>
                <Entry Text="{Binding Email}" Placeholder="email@example.com" Keyboard="Email" BackgroundColor="#F3F4F6" TextColor="#111827" PlaceholderColor="#9CA3AF" FontSize="15" HeightRequest="48" Margin="0,0,0,20"/>

                <Label IsVisible="{Binding HasMessage}" Text="{Binding Message}" TextColor="{Binding IsSuccess, Converter={StaticResource BoolToColorConverter}, ConverterParameter=#00FF00:#FF0000}" FontSize="14" HorizontalOptions="Center" Margin="0,0,0,15"/>

                <Button Text="Отправить код" Command="{Binding SendResetCodeCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" BackgroundColor="#6366F1" TextColor="White" FontSize="15" FontAttributes="Bold" HeightRequest="48" CornerRadius="24" Margin="0,5,0,15"/>

                <Button Text="← Вернуться ко входу" Command="{Binding GoBackCommand}" BackgroundColor="Transparent" TextColor="#6366F1" FontSize="14" HorizontalOptions="Center"/>
                
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>