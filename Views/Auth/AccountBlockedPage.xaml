<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OnlineTestingApp.Views.Auth.AccountBlockedPage"
             Title="Аккаунт заблокирован"
             BackgroundColor="{StaticResource Background}">

    <Grid>
        <Grid Background="{StaticResource SurfaceGradient}"/>
        
        <ScrollView>
            <VerticalStackLayout Spacing="30" Padding="30" VerticalOptions="Center">
                
                <!-- Замок -->
                <Border WidthRequest="120" 
                        HeightRequest="120"
                        HorizontalOptions="Center"
                        StrokeShape="RoundRectangle 60"
                        BackgroundColor="#FEE2E2"
                        Margin="0,0,0,10">
                    <Label Text="🔒" 
                           FontSize="64" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center"/>
                </Border>

                <!-- Заголовок -->
                <Label Text="Аккаунт деактивирован" 
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Error}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
                
                <!-- Сообщение -->
                <Border Style="{StaticResource CardStyle}"
                        BackgroundColor="{StaticResource Surface}"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        
                        <Label Text="⛔️"
                               FontSize="48"
                               HorizontalOptions="Center"/>
                        
                        <Label Text="Ваш аккаунт был деактивирован администратором"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalTextAlignment="Center"/>
                        
                        <Label Text="Это означает, что вы временно не можете войти в систему и использовать функционал платформы."
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}"
                               HorizontalTextAlignment="Center"/>
                        
                        <BoxView HeightRequest="1" 
                                 Color="{StaticResource SurfaceVariant}"
                                 Margin="0,10"/>
                        
                        <Label Text="Что делать?"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               Margin="0,0,0,10"/>
                        
                        <!-- Список действий - исправленная версия -->
                        <VerticalStackLayout Spacing="15">
                            
                            <!-- 1. Свяжитесь с администратором -->
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="1️⃣" 
                                       FontSize="16"
                                       WidthRequest="30"/>
                                <Label Text="Свяжитесь с администратором платформы"
                                       FontSize="14"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            
                            <!-- 2. Уточните причину -->
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="2️⃣" 
                                       FontSize="16"
                                       WidthRequest="30"/>
                                <Label Text="Уточните причину блокировки"
                                       FontSize="14"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            
                            <!-- 3. Дождитесь разблокировки -->
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="3️⃣" 
                                       FontSize="16"
                                       WidthRequest="30"/>
                                <Label Text="Дождитесь разблокировки администратором"
                                       FontSize="14"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            
                        </VerticalStackLayout>
                        
                    </VerticalStackLayout>
                </Border>

                <!-- Кнопка связи с поддержкой -->
                <Button Text="📧 Связаться с поддержкой"
                        Command="{Binding ContactSupportCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        FontSize="15"
                        FontAttributes="Bold"
                        HeightRequest="48"
                        CornerRadius="24"
                        Margin="0,10,0,0"/>

                <!-- Кнопка выхода -->
                <Button Text="← Вернуться на страницу входа"
                        Command="{Binding GoToLoginCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextSecondary}"
                        FontSize="14"
                        HeightRequest="48"
                        CornerRadius="24"/>
                
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>