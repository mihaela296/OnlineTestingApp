<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OnlineTestingApp.Converters"
             x:Class="OnlineTestingApp.Views.Auth.RegisterPage"
             Title="Регистрация"
             BackgroundColor="White">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:IsEqualConverter x:Key="IsEqualConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="24">
            
            <Label Text="Создать аккаунт" 
                   FontSize="28"
                   TextColor="#111827"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,4"/>
            
            <Label Text="Заполните форму для регистрации"
                   FontSize="14"
                   TextColor="#4B5563"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>

            <Label Text="Я хочу зарегистрироваться как"
                   TextColor="#374151"
                   FontSize="13"
                   Margin="0,0,0,2"/>
            
            <Picker ItemsSource="{Binding Roles}"
                   SelectedItem="{Binding RegisterModel.Role}"
                   BackgroundColor="#F3F4F6"
                   Title="Выберите роль"
                   FontSize="15"
                   HeightRequest="45"
                   Margin="0,0,0,10"/>

            <Label Text="Имя пользователя *"
                   TextColor="#374151"
                   FontSize="13"
                   Margin="0,0,0,2"/>
            
            <Entry Text="{Binding RegisterModel.Username}"
                   Placeholder="Придумайте имя"
                   BackgroundColor="#F3F4F6"
                   TextColor="#111827"
                   PlaceholderColor="#9CA3AF"
                   FontSize="15"
                   HeightRequest="45"
                   Margin="0,0,0,10"/>

            <Label Text="Email *"
                   TextColor="#374151"
                   FontSize="13"
                   Margin="0,0,0,2"/>
            
            <Entry Text="{Binding RegisterModel.Email}"
                   Placeholder="email@example.com"
                   Keyboard="Email"
                   BackgroundColor="#F3F4F6"
                   TextColor="#111827"
                   PlaceholderColor="#9CA3AF"
                   FontSize="15"
                   HeightRequest="45"
                   Margin="0,0,0,10"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="Имя"
                           TextColor="#374151"
                           FontSize="13"
                           Margin="0,0,0,2"/>
                    <Entry Text="{Binding RegisterModel.FirstName}"
                           Placeholder="Иван"
                           BackgroundColor="#F3F4F6"
                           TextColor="#111827"
                           PlaceholderColor="#9CA3AF"
                           FontSize="15"
                           HeightRequest="45"
                           Margin="0,0,0,10"/>
                </VerticalStackLayout>
                
                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Фамилия"
                           TextColor="#374151"
                           FontSize="13"
                           Margin="0,0,0,2"/>
                    <Entry Text="{Binding RegisterModel.LastName}"
                           Placeholder="Иванов"
                           BackgroundColor="#F3F4F6"
                           TextColor="#111827"
                           PlaceholderColor="#9CA3AF"
                           FontSize="15"
                           HeightRequest="45"
                           Margin="0,0,0,10"/>
                </VerticalStackLayout>
            </Grid>

            <Label Text="Телефон"
                   TextColor="#374151"
                   FontSize="13"
                   Margin="0,0,0,2"/>
            
            <Entry Text="{Binding RegisterModel.PhoneNumber}"
                   Placeholder="+7 (999) 123-45-67"
                   Keyboard="Telephone"
                   BackgroundColor="#F3F4F6"
                   TextColor="#111827"
                   PlaceholderColor="#9CA3AF"
                   FontSize="15"
                   HeightRequest="45"
                   Margin="0,0,0,10"/>

            <!-- Пароль с глазиком -->
            <Label Text="Пароль *"
                   TextColor="#374151"
                   FontSize="13"
                   Margin="0,0,0,2"/>
            
            <Grid ColumnDefinitions="*, 50" Margin="0,0,0,10">
                <Entry x:Name="PasswordEntry"
                       Grid.Column="0"
                       Text="{Binding RegisterModel.Password}"
                       Placeholder="Минимум 6 символов"
                       BackgroundColor="#F3F4F6"
                       TextColor="#111827"
                       PlaceholderColor="#9CA3AF"
                       IsPassword="True"
                       FontSize="15"
                       HeightRequest="45"/>
                
                <Button x:Name="TogglePasswordButton"
                        Grid.Column="1"
                        Clicked="OnTogglePasswordClicked"
                        BackgroundColor="Transparent"
                        Text="👁️"
                        FontSize="24"
                        TextColor="#6366F1"
                        HeightRequest="45"
                        WidthRequest="50"
                        Padding="0"/>
            </Grid>

            <!-- Подтверждение пароля с глазиком -->
            <Label Text="Подтвердите пароль *"
                   TextColor="#374151"
                   FontSize="13"
                   Margin="0,0,0,2"/>
            
            <Grid ColumnDefinitions="*, 50" Margin="0,0,0,10">
                <Entry x:Name="ConfirmPasswordEntry"
                       Grid.Column="0"
                       Text="{Binding RegisterModel.ConfirmPassword}"
                       Placeholder="Повторите пароль"
                       BackgroundColor="#F3F4F6"
                       TextColor="#111827"
                       PlaceholderColor="#9CA3AF"
                       IsPassword="True"
                       FontSize="15"
                       HeightRequest="45"/>
                
                <Button x:Name="ToggleConfirmPasswordButton"
                        Grid.Column="1"
                        Clicked="OnToggleConfirmPasswordClicked"
                        BackgroundColor="Transparent"
                        Text="👁️"
                        FontSize="24"
                        TextColor="#6366F1"
                        HeightRequest="45"
                        WidthRequest="50"
                        Padding="0"/>
            </Grid>

            <!-- Сообщение об ошибке -->
            <Border x:Name="ErrorFrame"
                   IsVisible="{Binding HasError}"
                   BackgroundColor="#FEE2E2"
                   Padding="10"
                   StrokeThickness="0"
                   Margin="0,0,0,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#DC2626"
                       FontSize="13"
                       HorizontalOptions="Center"/>
            </Border>

            <!-- Подсказка для учителя -->
            <Border x:Name="RoleHintFrame"
                   IsVisible="{Binding RegisterModel.Role, Converter={StaticResource IsEqualConverter}, ConverterParameter=Teacher}"
                   BackgroundColor="#EFF6FF"
                   Padding="10"
                   StrokeThickness="0"
                   Margin="0,0,0,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
                <Label Text="Регистрация учителя требует подтверждения администратором"
                       TextColor="#1E40AF"
                       FontSize="12"/>
            </Border>

            <!-- Кнопка регистрации - УМЕНЬШЕНА И ОТЦЕНТРИРОВАНА -->
            <Button Text="Зарегистрироваться"
                    Command="{Binding RegisterCommand}"
                    BackgroundColor="#6366F1"
                    TextColor="White"
                    FontSize="15"
                    FontAttributes="Bold"
                    HeightRequest="48"
                    WidthRequest="220"
                    HorizontalOptions="Center"
                    CornerRadius="24"
                    Margin="0,5,0,15"/>

<!-- Кнопка входа -->
<Button Text="Уже есть аккаунт? Войти"
        Command="{Binding GoToLoginCommand}"
        BackgroundColor="Transparent"
        TextColor="#6366F1"
        FontSize="13"
        HorizontalOptions="Center"
        Margin="0,10,0,0"/>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
