<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OnlineTestingApp.Converters"
             x:Class="OnlineTestingApp.Views.Auth.RegisterPage"
             Title="Регистрация"
             BackgroundColor="White">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:IsEqualConverter x:Key="IsEqualConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="24">
            
            <!-- Заголовок -->
            <Label Text="Создать аккаунт" 
                   FontSize="32"
                   TextColor="#111827"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,8"/>
            
            <Label Text="Заполните форму для регистрации"
                   FontSize="16"
                   TextColor="#4B5563"
                   HorizontalOptions="Center"
                   Margin="0,0,0,24"/>

            <!-- Роль -->
            <Label Text="Я хочу зарегистрироваться как"
                   TextColor="#374151"
                   FontSize="14"
                   Margin="0,0,0,4"/>
            
            <Picker ItemsSource="{Binding Roles}"
                   SelectedItem="{Binding RegisterModel.Role}"
                   BackgroundColor="#F3F4F6"
                   Title="Выберите роль"
                   FontSize="16"
                   HeightRequest="56"
                   Margin="0,0,0,16"/>

            <!-- Имя пользователя -->
            <Label Text="Имя пользователя *"
                   TextColor="#374151"
                   FontSize="14"
                   Margin="0,0,0,4"/>
            
            <Entry Text="{Binding RegisterModel.Username}"
                   Placeholder="Придумайте имя пользователя"
                   BackgroundColor="#F3F4F6"
                   TextColor="#111827"
                   PlaceholderColor="#9CA3AF"
                   FontSize="16"
                   HeightRequest="56"
                   Margin="0,0,0,16"/>

            <!-- Email -->
            <Label Text="Email *"
                   TextColor="#374151"
                   FontSize="14"
                   Margin="0,0,0,4"/>
            
            <Entry Text="{Binding RegisterModel.Email}"
                   Placeholder="Введите ваш email"
                   BackgroundColor="#F3F4F6"
                   TextColor="#111827"
                   PlaceholderColor="#9CA3AF"
                   Keyboard="Email"
                   FontSize="16"
                   HeightRequest="56"
                   Margin="0,0,0,16"/>

            <!-- Имя -->
            <Label Text="Имя"
                   TextColor="#374151"
                   FontSize="14"
                   Margin="0,0,0,4"/>
            
            <Entry Text="{Binding RegisterModel.FirstName}"
                   Placeholder="Иван"
                   BackgroundColor="#F3F4F6"
                   TextColor="#111827"
                   PlaceholderColor="#9CA3AF"
                   FontSize="16"
                   HeightRequest="56"
                   Margin="0,0,0,16"/>

            <!-- Фамилия -->
            <Label Text="Фамилия"
                   TextColor="#374151"
                   FontSize="14"
                   Margin="0,0,0,4"/>
            
            <Entry Text="{Binding RegisterModel.LastName}"
                   Placeholder="Иванов"
                   BackgroundColor="#F3F4F6"
                   TextColor="#111827"
                   PlaceholderColor="#9CA3AF"
                   FontSize="16"
                   HeightRequest="56"
                   Margin="0,0,0,16"/>

            <!-- Телефон -->
            <Label Text="Телефон"
                   TextColor="#374151"
                   FontSize="14"
                   Margin="0,0,0,4"/>
            
            <Entry Text="{Binding RegisterModel.PhoneNumber}"
                   Placeholder="+7 (999) 123-45-67"
                   BackgroundColor="#F3F4F6"
                   TextColor="#111827"
                   PlaceholderColor="#9CA3AF"
                   Keyboard="Telephone"
                   FontSize="16"
                   HeightRequest="56"
                   Margin="0,0,0,16"/>

            <!-- Пароль -->
            <Label Text="Пароль *"
                   TextColor="#374151"
                   FontSize="14"
                   Margin="0,0,0,4"/>
            
            <Entry Text="{Binding RegisterModel.Password}"
                   Placeholder="Минимум 6 символов"
                   BackgroundColor="#F3F4F6"
                   TextColor="#111827"
                   PlaceholderColor="#9CA3AF"
                   IsPassword="True"
                   FontSize="16"
                   HeightRequest="56"
                   Margin="0,0,0,16"/>

            <!-- Подтверждение пароля -->
            <Label Text="Подтвердите пароль *"
                   TextColor="#374151"
                   FontSize="14"
                   Margin="0,0,0,4"/>
            
            <Entry Text="{Binding RegisterModel.ConfirmPassword}"
                   Placeholder="Повторите пароль"
                   BackgroundColor="#F3F4F6"
                   TextColor="#111827"
                   PlaceholderColor="#9CA3AF"
                   IsPassword="True"
                   FontSize="16"
                   HeightRequest="56"
                   Margin="0,0,0,16"/>

            <!-- Сообщение об ошибке -->
            <Border x:Name="ErrorFrame"
                   IsVisible="{Binding HasError}"
                   BackgroundColor="#EF4444"
                   Padding="12"
                   StrokeThickness="0"
                   Margin="0,0,0,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Label Text="{Binding ErrorMessage}"
                       TextColor="White"
                       FontSize="14"
                       HorizontalOptions="Center"/>
            </Border>

            <!-- Подсказка для учителя -->
            <Border x:Name="RoleHintFrame"
                   IsVisible="{Binding RegisterModel.Role, Converter={StaticResource IsEqualConverter}, ConverterParameter=Teacher}"
                   BackgroundColor="#3B82F6"
                   Padding="12"
                   StrokeThickness="0"
                   Opacity="0.9"
                   Margin="0,0,0,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Label Text="Регистрация учителя требует подтверждения администратором. После регистрации вы получите уведомление."
                       TextColor="White"
                       FontSize="13"/>
            </Border>

            <!-- Кнопка регистрации -->
            <Button Text="Зарегистрироваться"
                    Command="{Binding RegisterCommand}"
                    BackgroundColor="#6366F1"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    HeightRequest="56"
                    CornerRadius="28"
                    Margin="0,0,0,16"/>

            <!-- Ссылка на вход - ИСПРАВЛЕНО -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Уже есть аккаунт?" 
                       TextColor="#4B5563"/>
                <Label Text="Войти"
                       TextColor="#6366F1">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
