<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OnlineTestingApp.Converters"
             x:Class="OnlineTestingApp.Views.Auth.RegisterPage"
             NavigationPage.HasNavigationBar="False">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:IsEqualConverter x:Key="IsEqualConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <Grid Background="{StaticResource BackgroundGradient}"/>
        
        <!-- Декоративные круги -->
        <Ellipse Fill="#2DD4BF08" WidthRequest="500" HeightRequest="500" HorizontalOptions="End" VerticalOptions="Start" Margin="0,-200,-150,0"/>
        <Ellipse Fill="#14B8A612" WidthRequest="400" HeightRequest="400" HorizontalOptions="Start" VerticalOptions="Center" Margin="-150,0,0,50"/>
        <Ellipse Fill="#5EEAD408" WidthRequest="300" HeightRequest="300" HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,-100"/>
        
        <ScrollView>
            <VerticalStackLayout Spacing="12" VerticalOptions="Center">
                
                <!-- Центрируем всё содержимое, ширина 450px -->
                <Frame Padding="0" Margin="0" HasShadow="False" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="12" HorizontalOptions="Center" WidthRequest="450">
                        
                        <Frame WidthRequest="80" 
                               HeightRequest="80" 
                               CornerRadius="40"
                               Background="{StaticResource PrimaryGradient}"
                               HasShadow="False"
                               HorizontalOptions="Center" 
                               Margin="0,20,0,20">
                            <Label Text="T" 
                                   FontSize="40" 
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center"/>
                        </Frame>
                        
                        <Label Text="Создать аккаунт" Style="{StaticResource TitleStyle}" Margin="0,0,0,4"/>
                        <Label Text="Присоединяйтесь к платформе" Style="{StaticResource SubtitleStyle}" Margin="0,0,0,24"/>

                        <!-- Роль -->
                        <Border Style="{StaticResource EntryStyle}">
                            <Picker ItemsSource="{Binding Roles}"
                                   SelectedItem="{Binding RegisterModel.Role}"
                                   Title="Я хочу зарегистрироваться как..."
                                   TextColor="{StaticResource TextPrimary}"/>
                        </Border>

                        <!-- Имя пользователя -->
                        <Border Style="{StaticResource EntryStyle}">
                            <Entry Text="{Binding RegisterModel.Username}"
                                   Placeholder="Имя пользователя"
                                   BackgroundColor="Transparent"/>
                        </Border>

                        <!-- Email -->
                        <Border Style="{StaticResource EntryStyle}">
                            <Entry Text="{Binding RegisterModel.Email}"
                                   Placeholder="Email"
                                   Keyboard="Email"
                                   BackgroundColor="Transparent"/>
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border Style="{StaticResource EntryStyle}" Grid.Column="0">
                                <Entry Text="{Binding RegisterModel.FirstName}"
                                       Placeholder="Имя"
                                       BackgroundColor="Transparent"/>
                            </Border>
                            
                            <Border Style="{StaticResource EntryStyle}" Grid.Column="1">
                                <Entry Text="{Binding RegisterModel.LastName}"
                                       Placeholder="Фамилия"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </Grid>

                        <!-- Телефон -->
                        <Border Style="{StaticResource EntryStyle}">
                            <Entry x:Name="PhoneEntry"
                                   Text="{Binding RegisterModel.PhoneNumber}"
                                   Placeholder="Телефон"
                                   Keyboard="Numeric"
                                   BackgroundColor="Transparent"
                                   MaxLength="18"/>
                        </Border>

                        <!-- Пароль -->
                        <Border Style="{StaticResource EntryStyle}">
                            <Grid ColumnDefinitions="*, Auto">
                                <Entry x:Name="PasswordEntry"
                                       Grid.Column="0"
                                       Text="{Binding RegisterModel.Password}"
                                       Placeholder="Пароль (минимум 6 символов)"
                                       IsPassword="True"
                                       BackgroundColor="Transparent"/>
                                <Button Grid.Column="1"
                                        Clicked="OnTogglePasswordClicked"
                                        BackgroundColor="Transparent"
                                        Text="👁"
                                        FontSize="18"
                                        TextColor="{StaticResource Primary}"
                                        WidthRequest="40"
                                        Padding="0"/>
                            </Grid>
                        </Border>

                        <!-- Подтверждение пароля -->
                        <Border Style="{StaticResource EntryStyle}">
                            <Grid ColumnDefinitions="*, Auto">
                                <Entry x:Name="ConfirmPasswordEntry"
                                       Grid.Column="0"
                                       Text="{Binding RegisterModel.ConfirmPassword}"
                                       Placeholder="Подтвердите пароль"
                                       IsPassword="True"
                                       BackgroundColor="Transparent"/>
                                <Button Grid.Column="1"
                                        Clicked="OnToggleConfirmPasswordClicked"
                                        BackgroundColor="Transparent"
                                        Text="👁"
                                        FontSize="18"
                                        TextColor="{StaticResource Primary}"
                                        WidthRequest="40"
                                        Padding="0"/>
                            </Grid>
                        </Border>

                        <Border IsVisible="{Binding HasError}"
                                BackgroundColor="{StaticResource ErrorLightBg}"
                                Padding="12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                Margin="0,4">
                            <Label Text="{Binding ErrorMessage}"
                                   TextColor="{StaticResource Error}"
                                   FontSize="13"
                                   HorizontalOptions="Center"/>
                        </Border>

                        <Border IsVisible="{Binding RegisterModel.Role, Converter={StaticResource IsEqualConverter}, ConverterParameter=Teacher}"
                                BackgroundColor="{StaticResource WarningLightBg}"
                                Padding="12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12">
                            <Label Text="Регистрация учителя требует подтверждения администратором"
                                   TextColor="{StaticResource Warning}"
                                   FontSize="12"
                                   HorizontalOptions="Center"/>
                        </Border>

                        <Button Text="Зарегистрироваться"
                                Command="{Binding RegisterCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                WidthRequest="220"
                                HorizontalOptions="Center"
                                Margin="0,16,0,8"/>

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="12" Margin="0,8">
                            <BoxView HeightRequest="1" WidthRequest="60" Color="#2DD4BF30" VerticalOptions="Center"/>
                            <Label Text="или" TextColor="{StaticResource TextMuted}" FontSize="13"/>
                            <BoxView HeightRequest="1" WidthRequest="60" Color="#2DD4BF30" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                            <Label Text="Уже есть аккаунт?" 
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="13"/>
                            <Button Text="Войти"
                                    Command="{Binding GoToLoginCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource Primary}"
                                    FontSize="13"
                                    FontAttributes="Bold"
                                    Padding="0"/>
                        </HorizontalStackLayout>
                        
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>