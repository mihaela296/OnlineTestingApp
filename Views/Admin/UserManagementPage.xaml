<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OnlineTestingApp.Converters"
             x:Class="OnlineTestingApp.Views.Admin.UserManagementPage"
             Title="Управление пользователями"
             BackgroundColor="{StaticResource Background}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопка создания -->
        <Grid Grid.Row="0" Padding="20,20,20,10" ColumnDefinitions="*, Auto">
            <Label Grid.Column="0" 
                   Text="👥 Пользователи" 
                   FontSize="24" 
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"/>
            
            <Button Grid.Column="1"
                    Text="+ Новый"
                    Command="{Binding CreateUserCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    FontSize="14"
                    HeightRequest="40"
                    CornerRadius="20"
                    Padding="15,0"/>
        </Grid>

        <!-- Фильтры -->
        <ScrollView Grid.Row="1" 
                   Orientation="Horizontal"
                   HeightRequest="50"
                   Margin="20,0,20,10">
            <HorizontalStackLayout Spacing="8">
                <Button Text="Все"
                        Command="{Binding FilterCommand}"
                        CommandParameter="all"
                        BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterBackgroundConverter}, ConverterParameter=all}"
                        TextColor="{Binding SelectedFilter, Converter={StaticResource FilterTextConverter}, ConverterParameter=all}"
                        FontSize="13"
                        HeightRequest="38"
                        CornerRadius="19"
                        Padding="15,0"/>
                
                <Button Text="Ученики"
                        Command="{Binding FilterCommand}"
                        CommandParameter="students"
                        BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterBackgroundConverter}, ConverterParameter=students}"
                        TextColor="{Binding SelectedFilter, Converter={StaticResource FilterTextConverter}, ConverterParameter=students}"
                        FontSize="13"
                        HeightRequest="38"
                        CornerRadius="19"
                        Padding="15,0"/>
                
                <Button Text="Учителя"
                        Command="{Binding FilterCommand}"
                        CommandParameter="teachers"
                        BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterBackgroundConverter}, ConverterParameter=teachers}"
                        TextColor="{Binding SelectedFilter, Converter={StaticResource FilterTextConverter}, ConverterParameter=teachers}"
                        FontSize="13"
                        HeightRequest="38"
                        CornerRadius="19"
                        Padding="15,0"/>
                
                <Button Text="Админы"
                        Command="{Binding FilterCommand}"
                        CommandParameter="admins"
                        BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterBackgroundConverter}, ConverterParameter=admins}"
                        TextColor="{Binding SelectedFilter, Converter={StaticResource FilterTextConverter}, ConverterParameter=admins}"
                        FontSize="13"
                        HeightRequest="38"
                        CornerRadius="19"
                        Padding="15,0"/>
                
                <Button Text="Активные"
                        Command="{Binding FilterCommand}"
                        CommandParameter="active"
                        BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterBackgroundConverter}, ConverterParameter=active}"
                        TextColor="{Binding SelectedFilter, Converter={StaticResource FilterTextConverter}, ConverterParameter=active}"
                        FontSize="13"
                        HeightRequest="38"
                        CornerRadius="19"
                        Padding="15,0"/>
                
                <Button Text="Заблок."
                        Command="{Binding FilterCommand}"
                        CommandParameter="inactive"
                        BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterBackgroundConverter}, ConverterParameter=inactive}"
                        TextColor="{Binding SelectedFilter, Converter={StaticResource FilterTextConverter}, ConverterParameter=inactive}"
                        FontSize="13"
                        HeightRequest="38"
                        CornerRadius="19"
                        Padding="15,0"/>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Поиск -->
        <Border Grid.Row="2" 
                Margin="20,0,20,10"
                StrokeShape="RoundRectangle 12"
                Stroke="{StaticResource SurfaceVariant}"
                BackgroundColor="{StaticResource Surface}">
            <Grid ColumnDefinitions="Auto, *" Padding="12">
                <Label Grid.Column="0" Text="🔍" FontSize="18" VerticalOptions="Center"/>
                <Entry Grid.Column="1"
                       x:Name="SearchEntry"
                       Text="{Binding SearchText}"
                       Placeholder="Поиск по имени или email..."
                       BackgroundColor="Transparent"
                       FontSize="14"
                       VerticalOptions="Center"/>
            </Grid>
        </Border>

        <!-- Список пользователей -->
        <CollectionView Grid.Row="3"
                       ItemsSource="{Binding Users}"
                       Margin="20,0,20,20">
            
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="20" 
                                    VerticalOptions="Center" 
                                    HorizontalOptions="Center">
                    <Label Text="📭" FontSize="64" HorizontalOptions="Center"/>
                    <Label Text="Пользователи не найдены" 
                           FontSize="16" 
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <Grid RowDefinitions="Auto, Auto, Auto" 
                              ColumnDefinitions="Auto, *, Auto"
                              Padding="15">
                            
                            <!-- Аватар -->
                            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3"
                                   WidthRequest="50" HeightRequest="50"
                                   StrokeShape="RoundRectangle 25"
                                   BackgroundColor="{Binding RoleColor}"
                                   Margin="0,0,12,0">
                                <Label Text="{Binding Username[0]}" 
                                       FontSize="20" 
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"/>
                            </Border>
                            
                            <!-- Имя и роль -->
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding FullName}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   LineBreakMode="TailTruncation"/>
                            
                            <!-- Роль и статус -->
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="8">
                                <Border BackgroundColor="{Binding RoleColor}"
                                       Padding="8,4"
                                       StrokeThickness="0"
                                       StrokeShape="RoundRectangle 12">
                                    <Label Text="{Binding Role}"
                                           TextColor="White"
                                           FontSize="11"
                                           FontAttributes="Bold"/>
                                </Border>
                                
                                <Border BackgroundColor="{Binding IsActive, Converter={StaticResource StatusBackgroundConverter}}"
                                       Padding="8,4"
                                       StrokeThickness="0"
                                       StrokeShape="RoundRectangle 12">
                                    <Label Text="{Binding Status}"
                                           TextColor="White"
                                           FontSize="11"/>
                                </Border>
                            </HorizontalStackLayout>
                            
                            <!-- Email -->
                            <Label Grid.Row="2" Grid.Column="1"
                                   Text="{Binding Email}"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}"
                                   LineBreakMode="TailTruncation"/>
                            
                            <!-- Кнопки действий -->
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="2" 
                                                  Grid.RowSpan="3"
                                                  Spacing="8"
                                                  VerticalOptions="Center">
                                
                                <!-- Редактировать -->
                                <Button Text="✎"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditCommand}"
                                        CommandParameter="{Binding UserId}"
                                        BackgroundColor="{StaticResource Info}"
                                        TextColor="White"
                                        FontSize="14"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        CornerRadius="20"/>
                                
                                <!-- Активировать/Деактивировать -->
                                <Button Text="{Binding IsActive, Converter={StaticResource ToggleStatusIconConverter}}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleStatusCommand}"
                                        CommandParameter="{Binding UserId}"
                                        BackgroundColor="{Binding IsActive, Converter={StaticResource ToggleStatusColorConverter}}"
                                        TextColor="White"
                                        FontSize="14"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        CornerRadius="20"/>
                                
                                <!-- Удалить -->
                                <Button Text="🗑️"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCommand}"
                                        CommandParameter="{Binding UserId}"
                                        BackgroundColor="{StaticResource Error}"
                                        TextColor="White"
                                        FontSize="14"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        CornerRadius="20"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Индикатор загрузки -->
        <ActivityIndicator Grid.Row="0" Grid.RowSpan="4"
                          IsRunning="{Binding IsBusy}"
                          IsVisible="{Binding IsBusy}"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          Color="{StaticResource Primary}"
                          Scale="2"/>
    </Grid>
</ContentPage>