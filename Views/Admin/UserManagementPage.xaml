<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OnlineTestingApp.Converters"
             x:Class="OnlineTestingApp.Views.Admin.UserManagementPage"
             Title="Управление пользователями">

    <Grid>
        <Grid Background="{StaticResource BackgroundGradient}"/>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Grid Grid.Row="0" Padding="20,20,20,10" ColumnDefinitions="*, Auto">
            <Label Grid.Column="0" 
                   Text="👥 Пользователи" 
                   FontSize="24" 
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}"/>
            
            <Button Grid.Column="1"
                    Text="+ Новый"
                    Command="{Binding CreateUserCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    HeightRequest="40"
                    CornerRadius="20"
                    Padding="15,0"/>
        </Grid>

        <!-- Фильтры с выделением активного -->
        <ScrollView Grid.Row="1" 
                   Orientation="Horizontal"
                   HeightRequest="55"
                   Margin="20,0,20,10">
            <HorizontalStackLayout Spacing="12">
                
                <!-- Кнопка Все -->
                <Button Text="Все"
                        Command="{Binding FilterCommand}"
                        CommandParameter="all"
                        CornerRadius="22"
                        HeightRequest="44"
                        Padding="20,0"
                        FontSize="14"
                        FontAttributes="Bold">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedFilter}"
                                     Value="all">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                            <Setter Property="TextColor" Value="White"/>
                        </DataTrigger>
                    </Button.Triggers>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceVariant}"/>
                            <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                        </Style>
                    </Button.Style>
                </Button>
                
                <!-- Кнопка Ученики -->
                <Button Text="Ученики"
                        Command="{Binding FilterCommand}"
                        CommandParameter="students"
                        CornerRadius="22"
                        HeightRequest="44"
                        Padding="20,0"
                        FontSize="14"
                        FontAttributes="Bold">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedFilter}"
                                     Value="students">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                            <Setter Property="TextColor" Value="White"/>
                        </DataTrigger>
                    </Button.Triggers>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceVariant}"/>
                            <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                        </Style>
                    </Button.Style>
                </Button>
                
                <!-- Кнопка Учителя -->
                <Button Text="Учителя"
                        Command="{Binding FilterCommand}"
                        CommandParameter="teachers"
                        CornerRadius="22"
                        HeightRequest="44"
                        Padding="20,0"
                        FontSize="14"
                        FontAttributes="Bold">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedFilter}"
                                     Value="teachers">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                            <Setter Property="TextColor" Value="White"/>
                        </DataTrigger>
                    </Button.Triggers>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceVariant}"/>
                            <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                        </Style>
                    </Button.Style>
                </Button>
                
                <!-- Кнопка Админы -->
                <Button Text="Админы"
                        Command="{Binding FilterCommand}"
                        CommandParameter="admins"
                        CornerRadius="22"
                        HeightRequest="44"
                        Padding="20,0"
                        FontSize="14"
                        FontAttributes="Bold">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedFilter}"
                                     Value="admins">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                            <Setter Property="TextColor" Value="White"/>
                        </DataTrigger>
                    </Button.Triggers>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceVariant}"/>
                            <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                        </Style>
                    </Button.Style>
                </Button>
                
                <!-- Кнопка Активные -->
                <Button Text="Активные"
                        Command="{Binding FilterCommand}"
                        CommandParameter="active"
                        CornerRadius="22"
                        HeightRequest="44"
                        Padding="20,0"
                        FontSize="14"
                        FontAttributes="Bold">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedFilter}"
                                     Value="active">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                            <Setter Property="TextColor" Value="White"/>
                        </DataTrigger>
                    </Button.Triggers>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceVariant}"/>
                            <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                        </Style>
                    </Button.Style>
                </Button>
                
                <!-- Кнопка Заблокированные -->
                <Button Text="Заблок."
                        Command="{Binding FilterCommand}"
                        CommandParameter="inactive"
                        CornerRadius="22"
                        HeightRequest="44"
                        Padding="20,0"
                        FontSize="14"
                        FontAttributes="Bold">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedFilter}"
                                     Value="inactive">
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                            <Setter Property="TextColor" Value="White"/>
                        </DataTrigger>
                    </Button.Triggers>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceVariant}"/>
                            <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                        </Style>
                    </Button.Style>
                </Button>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Поиск -->
        <Border Grid.Row="2" 
                Margin="20,0,20,10"
                StrokeShape="RoundRectangle 14"
                Stroke="{StaticResource Primary30}"
                Background="{StaticResource Surface}">
            <Grid ColumnDefinitions="Auto, *" Padding="14">
                <Label Grid.Column="0" Text="🔍" FontSize="18" VerticalOptions="Center"
                       TextColor="{StaticResource Primary}"/>
                <Entry Grid.Column="1"
                       x:Name="SearchEntry"
                       Text="{Binding SearchText}"
                       Placeholder="Поиск по имени или email..."
                       BackgroundColor="Transparent"
                       FontSize="14"
                       VerticalOptions="Center"/>
            </Grid>
        </Border>

        <!-- Список пользователей -->
        <CollectionView Grid.Row="3"
                       ItemsSource="{Binding Users}"
                       Margin="20,0,20,20">
            
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="20" 
                                    VerticalOptions="Center" 
                                    HorizontalOptions="Center">
                    <Label Text="📭" FontSize="64" HorizontalOptions="Center"/>
                    <Label Text="Пользователи не найдены" 
                           FontSize="16" 
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,12"
                            Padding="0"
                            StrokeThickness="0"
                            Background="{StaticResource Surface}"
                            StrokeShape="RoundRectangle 20">
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource ShadowColor}" 
                                    Radius="12" 
                                    Offset="0,3" 
                                    Opacity="0.15"/>
                        </Border.Shadow>
                        
                        <Grid RowDefinitions="Auto, Auto, Auto" 
                              ColumnDefinitions="Auto, *, Auto"
                              Padding="15">
                            
                            <!-- Аватар -->
                            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3"
                                   WidthRequest="50" HeightRequest="50"
                                   StrokeShape="RoundRectangle 25"
                                   BackgroundColor="{Binding RoleColor}"
                                   Margin="0,0,12,0">
                                <Label Text="{Binding Username[0]}" 
                                       FontSize="20" 
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"/>
                            </Border>
                            
                            <!-- Имя -->
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding FullName}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            
                            <!-- Роль и статус -->
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="8">
                                <Border BackgroundColor="{Binding RoleColor}"
                                       Padding="8,4"
                                       StrokeThickness="0"
                                       StrokeShape="RoundRectangle 12">
                                    <Label Text="{Binding Role}"
                                           TextColor="White"
                                           FontSize="11"
                                           FontAttributes="Bold"/>
                                </Border>
                                
                                <Border BackgroundColor="{Binding IsActive, Converter={StaticResource StatusBackgroundConverter}}"
                                       Padding="8,4"
                                       StrokeThickness="0"
                                       StrokeShape="RoundRectangle 12">
                                    <Label Text="{Binding Status}"
                                           TextColor="White"
                                           FontSize="11"/>
                                </Border>
                            </HorizontalStackLayout>
                            
                            <!-- Email -->
                            <Label Grid.Row="2" Grid.Column="1"
                                   Text="{Binding Email}"
                                   FontSize="12"
                                   TextColor="{StaticResource TextMuted}"/>
                            
                            <!-- Кнопки действий -->
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="2" 
                                                  Grid.RowSpan="3"
                                                  Spacing="8"
                                                  VerticalOptions="Center">
                                
                                <Button Text="✎"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditCommand}"
                                        CommandParameter="{Binding UserId}"
                                        BackgroundColor="{StaticResource Primary}"
                                        TextColor="White"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        CornerRadius="20"/>
                                
                                <Button Text="{Binding IsActive, Converter={StaticResource ToggleStatusIconConverter}}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleStatusCommand}"
                                        CommandParameter="{Binding UserId}"
                                        BackgroundColor="{StaticResource PrimaryLight}"
                                        TextColor="White"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        CornerRadius="20"/>
                                
                                <Button Text="🗑️"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCommand}"
                                        CommandParameter="{Binding UserId}"
                                        BackgroundColor="{StaticResource PrimaryDark}"
                                        TextColor="White"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        CornerRadius="20"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.Row="0" Grid.RowSpan="4"
                          IsRunning="{Binding IsBusy}"
                          IsVisible="{Binding IsBusy}"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          Color="{StaticResource Primary}"
                          Scale="2"/>
    </Grid>
</ContentPage>