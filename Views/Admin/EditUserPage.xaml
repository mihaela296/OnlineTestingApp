<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="OnlineTestingApp.Views.Admin.EditUserPage"
             Title="Редактирование пользователя">

    <Grid>
        <Grid Background="{StaticResource BackgroundGradient}"/>
        
        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="25" VerticalOptions="Center">
                
                <Frame Padding="0" Margin="0" HasShadow="False" BackgroundColor="Transparent">
                    <VerticalStackLayout Spacing="20" HorizontalOptions="Center" WidthRequest="450">
                        
                        <!-- Аватар -->
                        <Border WidthRequest="100" 
                                HeightRequest="100"
                                HorizontalOptions="Center"
                                StrokeShape="RoundRectangle 50"
                                BackgroundColor="{Binding User.RoleColor}"
                                Margin="0,0,0,10">
                            <Label Text="{Binding User.Username[0]}" 
                                   FontSize="48" 
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center"/>
                        </Border>

                        <Label Text="Редактирование профиля" 
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center"/>
                        
                        <Label Text="{Binding User.Email}"
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}"
                               HorizontalOptions="Center"
                               Margin="0,-10,0,10"/>

                        <!-- Форма -->
                        <Border Style="{StaticResource CardStyle}" Padding="20">
                            <VerticalStackLayout Spacing="15">
                                
                                <Label Text="Имя пользователя"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <Border Style="{StaticResource EntryStyle}">
                                    <Entry Text="{Binding EditUsername}"
                                           Placeholder="Введите имя пользователя"
                                           BackgroundColor="Transparent"/>
                                </Border>
                                
                                <Label Text="Имя"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <Border Style="{StaticResource EntryStyle}">
                                    <Entry Text="{Binding EditFirstName}"
                                           Placeholder="Введите имя"
                                           BackgroundColor="Transparent"/>
                                </Border>
                                
                                <Label Text="Фамилия"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <Border Style="{StaticResource EntryStyle}">
                                    <Entry Text="{Binding EditLastName}"
                                           Placeholder="Введите фамилию"
                                           BackgroundColor="Transparent"/>
                                </Border>
                                
                                <Label Text="Email"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <Border Style="{StaticResource EntryStyle}">
                                    <Entry Text="{Binding EditEmail}"
                                           Placeholder="Введите email"
                                           Keyboard="Email"
                                           BackgroundColor="Transparent"/>
                                </Border>
                                
                                <Label Text="Телефон"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <Border Style="{StaticResource EntryStyle}">
                                    <Entry Text="{Binding EditPhoneNumber}"
                                           Placeholder="+7 (999) 123-45-67"
                                           Keyboard="Numeric"
                                           BackgroundColor="Transparent"
                                           MaxLength="18"/>
                                </Border>
                                
                                <Label Text="Роль"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <Border Style="{StaticResource EntryStyle}">
                                    <Picker ItemsSource="{Binding Roles}"
                                           SelectedItem="{Binding EditRole}"
                                           BackgroundColor="Transparent"/>
                                </Border>
                                
                                <Label Text="Статус аккаунта"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <Grid ColumnDefinitions="Auto, *" Margin="0,5">
                                    <Switch Grid.Column="0"
                                            IsToggled="{Binding EditIsActive}"
                                            OnColor="{StaticResource Success}"
                                            ThumbColor="White"
                                            Margin="0,0,10,0"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding StatusText}"
                                           TextColor="{Binding EditIsActive, Converter={StaticResource BoolToColorConverter}, ConverterParameter=#10B981:#EF4444}"
                                           VerticalOptions="Center"
                                           FontSize="14"/>
                                </Grid>
                                
                                <Border IsVisible="{Binding HasError}"
                                        BackgroundColor="{StaticResource ErrorLightBg}"
                                        Padding="10"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8">
                                    <Label Text="{Binding ErrorMessage}"
                                           TextColor="{StaticResource Error}"
                                           FontSize="13"/>
                                </Border>
                                
                            </VerticalStackLayout>
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Grid.Column="0"
                                    Text="Отмена"
                                    Command="{Binding CancelCommand}"
                                    BackgroundColor="{StaticResource SurfaceVariant}"
                                    TextColor="{StaticResource TextSecondary}"
                                    FontSize="15"
                                    FontAttributes="Bold"
                                    HeightRequest="48"
                                    CornerRadius="24"/>
                            
                            <Button Grid.Column="1"
                                    Text="Сохранить"
                                    Command="{Binding SaveCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"
                                    FontSize="15"
                                    FontAttributes="Bold"
                                    HeightRequest="48"
                                    CornerRadius="24"
                                    IsEnabled="{Binding IsValid}"/>
                        </Grid>

                        <ActivityIndicator IsRunning="{Binding IsSaving}"
                                          IsVisible="{Binding IsSaving}"
                                          Color="{StaticResource Primary}"
                                          Scale="1.5"/>
                        
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>