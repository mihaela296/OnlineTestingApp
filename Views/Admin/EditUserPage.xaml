<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="OnlineTestingApp.Views.Admin.EditUserPage"
             Title="Редактирование пользователя"
             BackgroundColor="{StaticResource Background}">

    <Grid>
        <Grid Background="{StaticResource SurfaceGradient}"/>
        
        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="25">
                
                <!-- Заголовок с аватаром -->
                <Border WidthRequest="100" 
                        HeightRequest="100"
                        HorizontalOptions="Center"
                        StrokeShape="RoundRectangle 50"
                        BackgroundColor="{Binding User.RoleColor}"
                        Margin="0,0,0,10">
                    <Label Text="{Binding User.Username[0]}" 
                           FontSize="48" 
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" 
                           VerticalOptions="Center"/>
                </Border>

                <Label Text="Редактирование профиля" 
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
                
                <Label Text="{Binding User.Email}"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalOptions="Center"
                       Margin="0,-10,0,10"/>

                <!-- Форма редактирования -->
                <Border Style="{StaticResource CardStyle}" Padding="20">
                    <VerticalStackLayout Spacing="15">
                        
                        <!-- Имя пользователя -->
                        <Label Text="Имя пользователя"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Entry Text="{Binding EditUsername}"
                               Placeholder="Введите имя пользователя"
                               BackgroundColor="{StaticResource SurfaceVariant}"
                               FontSize="15"
                               HeightRequest="45">
                            <Entry.Behaviors>
                                <toolkit:EventToCommandBehavior EventName="TextChanged" 
                                                                Command="{Binding ValidateUsernameCommand}"/>
                            </Entry.Behaviors>
                        </Entry>
                        
                        <!-- Имя -->
                        <Label Text="Имя"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Entry Text="{Binding EditFirstName}"
                               Placeholder="Введите имя"
                               BackgroundColor="{StaticResource SurfaceVariant}"
                               FontSize="15"
                               HeightRequest="45"/>
                        
                        <!-- Фамилия -->
                        <Label Text="Фамилия"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Entry Text="{Binding EditLastName}"
                               Placeholder="Введите фамилию"
                               BackgroundColor="{StaticResource SurfaceVariant}"
                               FontSize="15"
                               HeightRequest="45"/>
                        
                        <!-- Email -->
                        <Label Text="Email"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Entry Text="{Binding EditEmail}"
                               Placeholder="Введите email"
                               Keyboard="Email"
                               BackgroundColor="{StaticResource SurfaceVariant}"
                               FontSize="15"
                               HeightRequest="45">
                            <Entry.Behaviors>
                                <toolkit:EventToCommandBehavior EventName="TextChanged" 
                                                                Command="{Binding ValidateEmailCommand}"/>
                            </Entry.Behaviors>
                        </Entry>
                        
                        <!-- Телефон (ИСПРАВЛЕНО) -->
                        <Label Text="Телефон"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Entry Text="{Binding EditPhoneNumber}"
                               Placeholder="+7 (999) 123-45-67"
                               Keyboard="Numeric"
                               BackgroundColor="{StaticResource SurfaceVariant}"
                               FontSize="15"
                               HeightRequest="45"
                               MaxLength="18">
                            <Entry.Behaviors>
                                <toolkit:MaskedBehavior Mask="+X (XXX) XXX-XX-XX"
                                                       UnmaskedCharacter="X"/>
                            </Entry.Behaviors>
                        </Entry>
                        
                        <!-- Роль -->
                        <Label Text="Роль"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Picker ItemsSource="{Binding Roles}"
                               SelectedItem="{Binding EditRole}"
                               BackgroundColor="{StaticResource SurfaceVariant}"
                               FontSize="15"
                               HeightRequest="45"/>
                        
                        <!-- Статус -->
                        <Label Text="Статус аккаунта"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Grid ColumnDefinitions="Auto, *" Margin="0,5">
                            <Switch Grid.Column="0"
                                    IsToggled="{Binding EditIsActive}"
                                    OnColor="{StaticResource Success}"
                                    ThumbColor="White"
                                    Margin="0,0,10,0"/>
                            <Label Grid.Column="1"
                                   Text="{Binding StatusText}"
                                   TextColor="{Binding EditIsActive, Converter={StaticResource BoolToColorConverter}, ConverterParameter=#10B981:#EF4444}"
                                   VerticalOptions="Center"
                                   FontSize="14"/>
                        </Grid>
                        
                        <!-- Сообщение об ошибке -->
                        <Border IsVisible="{Binding HasError}"
                                BackgroundColor="#FEE2E2"
                                Padding="10"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 8">
                            <Label Text="{Binding ErrorMessage}"
                                   TextColor="#DC2626"
                                   FontSize="13"/>
                        </Border>
                        
                    </VerticalStackLayout>
                </Border>

                <!-- Кнопки действий -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    
                    <Button Grid.Column="0"
                            Text="Отмена"
                            Command="{Binding CancelCommand}"
                            BackgroundColor="{StaticResource SurfaceVariant}"
                            TextColor="{StaticResource TextPrimary}"
                            FontSize="15"
                            FontAttributes="Bold"
                            HeightRequest="48"
                            CornerRadius="24"/>
                    
                    <Button Grid.Column="1"
                            Text="Сохранить"
                            Command="{Binding SaveCommand}"
                            BackgroundColor="{StaticResource Success}"
                            TextColor="White"
                            FontSize="15"
                            FontAttributes="Bold"
                            HeightRequest="48"
                            CornerRadius="24"
                            IsEnabled="{Binding IsValid}"/>
                    
                </Grid>

                <!-- Индикатор загрузки -->
                <ActivityIndicator IsRunning="{Binding IsSaving}"
                                  IsVisible="{Binding IsSaving}"
                                  Color="{StaticResource Primary}"
                                  Scale="1.5"/>
                
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>