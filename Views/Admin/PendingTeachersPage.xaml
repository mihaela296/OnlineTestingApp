<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OnlineTestingApp.Views.Admin.PendingTeachersPage"
             Title="Ожидают подтверждения">

    <Grid>
        <Grid Background="{StaticResource BackgroundGradient}"/>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" 
                Style="{StaticResource StatsCardStyle}"
                Margin="20,20,20,10">
            <Grid ColumnDefinitions="Auto, *" Padding="12">
                <Border Grid.Column="0" 
                        WidthRequest="50" HeightRequest="50"
                        StrokeShape="RoundRectangle 25"
                        BackgroundColor="{StaticResource Primary20}"
                        Margin="0,0,12,0">
                    <Label Text="⏳" FontSize="24" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center"/>
                </Border>
                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Ожидают подтверждения" 
                           FontSize="20" 
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"/>
                    <Label Text="{Binding PendingCount, StringFormat='Всего: {0} учителей'}" 
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Список учителей -->
        <CollectionView Grid.Row="1"
                       ItemsSource="{Binding PendingTeachers}"
                       Margin="20,0,20,20">
            
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="20" 
                                    VerticalOptions="Center" 
                                    HorizontalOptions="Center">
                    <Label Text="✅" FontSize="64" HorizontalOptions="Center"/>
                    <Label Text="Нет ожидающих учителей" 
                           FontSize="16" 
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <Grid RowDefinitions="Auto, Auto, Auto" 
                              ColumnDefinitions="Auto, *, Auto"
                              Padding="15">
                            
                            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3"
                                   WidthRequest="50" HeightRequest="50"
                                   StrokeShape="RoundRectangle 25"
                                   BackgroundColor="{StaticResource Primary40}"
                                   Margin="0,0,12,0">
                                <Label Text="{Binding Username[0]}" 
                                       FontSize="20" 
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"/>
                            </Border>
                            
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding FullName}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding Email}"
                                   FontSize="14"
                                   TextColor="{StaticResource TextSecondary}"/>
                            
                            <Label Grid.Row="2" Grid.Column="1"
                                   Text="{Binding CreatedAt, StringFormat='Зарегистрирован: {0:dd.MM.yyyy}'}"
                                   FontSize="12"
                                   TextColor="{StaticResource TextMuted}"/>
                            
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="2" 
                                                  Grid.RowSpan="3"
                                                  Spacing="8"
                                                  VerticalOptions="Center">
                                
                                <Button Text="✓"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ApproveCommand}"
                                        CommandParameter="{Binding UserId}"
                                        BackgroundColor="{StaticResource Success}"
                                        TextColor="White"
                                        FontSize="16"
                                        FontAttributes="Bold"
                                        WidthRequest="45"
                                        HeightRequest="45"
                                        CornerRadius="23"/>
                                
                                <Button Text="✗"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RejectCommand}"
                                        CommandParameter="{Binding UserId}"
                                        BackgroundColor="{StaticResource Accent}"
                                        TextColor="White"
                                        FontSize="16"
                                        FontAttributes="Bold"
                                        WidthRequest="45"
                                        HeightRequest="45"
                                        CornerRadius="23"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>