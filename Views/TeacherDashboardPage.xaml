<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OnlineTestingApp.Views.TeacherDashboardPage"
             Title="Панель учителя"
             NavigationPage.HasNavigationBar="True">
    
    <Grid>
        <Grid Background="{StaticResource BackgroundGradient}"/>
        
        <Ellipse Fill="#2DD4BF08"
                 WidthRequest="550"
                 HeightRequest="550"
                 HorizontalOptions="Start"
                 VerticalOptions="Start"
                 Margin="-250,-200,0,0"/>
        
        <Ellipse Fill="#2DD4BF12"
                 WidthRequest="450"
                 HeightRequest="450"
                 HorizontalOptions="End"
                 VerticalOptions="Center"
                 Margin="0,0,-200,50"/>
        
        <ScrollView>
            <VerticalStackLayout Spacing="25" Padding="25" VerticalOptions="Center">
                
                <Border WidthRequest="100"
                        HeightRequest="100"
                        HorizontalOptions="Center"
                        StrokeShape="RoundRectangle 50"
                        Background="{StaticResource PrimaryGradient}"
                        Margin="0,0,0,20">
                    <Label Text="👨‍🏫" 
                           FontSize="48" 
                           TextColor="White"
                           HorizontalOptions="Center" 
                           VerticalOptions="Center"/>
                </Border>
                
                <Label Text="Панель учителя" 
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center"/>
                
                <Label Text="Страница в разработке"
                       FontSize="16"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalOptions="Center"
                       Margin="0,0,0,20"/>
                
                <Button Text="Выйти из аккаунта"
                        x:Name="LogoutButton"
                        BackgroundColor="{StaticResource SurfaceVariant}"
                        TextColor="{StaticResource Error}"
                        FontSize="15"
                        FontAttributes="Bold"
                        HeightRequest="48"
                        CornerRadius="24"
                        WidthRequest="200"
                        HorizontalOptions="Center"
                        Margin="0,40,0,0"/>
                
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>