<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OnlineTestingApp.Views.AdminDashboardPage"
             Title="Панель администратора"
             BackgroundColor="{StaticResource Background}">
    
    <Grid>
        <Grid Background="{StaticResource SurfaceGradient}"/>
        <ScrollView>
            <VerticalStackLayout Spacing="30" Padding="30" VerticalOptions="Center">
                <Label Text="👑" FontSize="64" HorizontalOptions="Center"/>
                <Label Text="Панель администратора" Style="{StaticResource TitleStyle}"/>
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="20" Padding="20">
                        <Label Text="Добро пожаловать!" FontSize="18" FontFamily="OpenSansSemibold" TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
                        <Label Text="Страница в разработке" FontSize="16" TextColor="{StaticResource TextSecondary}" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Button Text="Выйти из аккаунта" x:Name="LogoutButton" BackgroundColor="{StaticResource Error}" TextColor="White" Style="{StaticResource PrimaryButtonStyle}"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
