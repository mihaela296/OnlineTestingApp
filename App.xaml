<?xml version="1.0" encoding="UTF-8"?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:OnlineTestingApp"
             xmlns:converters="clr-namespace:OnlineTestingApp.Converters"
             x:Class="OnlineTestingApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Конвертеры -->
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:IsEqualConverter x:Key="IsEqualConverter"/>
            <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <converters:BoolToEyeConverter x:Key="BoolToEyeConverter"/>
            <converters:FirstLetterConverter x:Key="FirstLetterConverter"/>
            <converters:FilterBackgroundConverter x:Key="FilterBackgroundConverter"/>
            <converters:FilterTextConverter x:Key="FilterTextConverter"/>
            <converters:StatusBackgroundConverter x:Key="StatusBackgroundConverter"/>
            <converters:ToggleStatusIconConverter x:Key="ToggleStatusIconConverter"/>
            <converters:ToggleStatusColorConverter x:Key="ToggleStatusColorConverter"/>
            <converters:IsTeacherConverter x:Key="IsTeacherConverter"/>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>