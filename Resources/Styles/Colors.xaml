<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Основные цвета -->
    <Color x:Key="Primary">#6366F1</Color>
    <Color x:Key="PrimaryDark">#4F46E5</Color>
    <Color x:Key="Secondary">#8B5CF6</Color>
    <Color x:Key="Accent">#EC4899</Color>
    
    <!-- Фоновые цвета -->
    <Color x:Key="Background">#F9FAFB</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceVariant">#F3F4F6</Color>
    
    <!-- Текст -->
    <Color x:Key="Text">#1F2937</Color>
    <Color x:Key="TextSecondary">#6B7280</Color>
    <Color x:Key="TextLight">#9CA3AF</Color>
    
    <!-- Состояния -->
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Error">#EF4444</Color>
    <Color x:Key="Info">#3B82F6</Color>
    
    <!-- Градиенты -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#6366F1" Offset="0.1"/>
        <GradientStop Color="#8B5CF6" Offset="0.5"/>
        <GradientStop Color="#EC4899" Offset="1.0"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="SurfaceGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F9FAFB" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>