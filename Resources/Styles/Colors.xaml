<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ========== ОСНОВНЫЕ ЦВЕТА ========== -->
    <Color x:Key="Primary">#2DD4BF</Color>           
    <Color x:Key="PrimaryLight">#5EEAD4</Color>      
    <Color x:Key="PrimaryDark">#14B8A6</Color>       
    <Color x:Key="PrimarySoft">#E6F7F3</Color>       
    
    <Color x:Key="Accent">#F59E0B</Color>
    <Color x:Key="AccentLight">#FBBF24</Color>
    
    <!-- Цвета для фильтров -->
    <Color x:Key="FilterActive">#2DD4BF</Color>
    <Color x:Key="FilterInactive">#F0F7F4</Color>
    
    <!-- Цвета с прозрачностью -->
    <Color x:Key="Primary10">#2DD4BF10</Color>
    <Color x:Key="Primary20">#2DD4BF20</Color>
    <Color x:Key="Primary30">#2DD4BF30</Color>
    <Color x:Key="Primary40">#2DD4BF40</Color>
    
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#0F172A</Color>
    <Color x:Key="DarkGray">#1E293B</Color>
    <Color x:Key="Gray">#334155</Color>
    <Color x:Key="LightGray">#F1F5F9</Color>
    
    <!-- ========== ФОНОВЫЕ ГРАДИЕНТЫ ========== -->
    <LinearGradientBrush x:Key="BackgroundGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F0FDF9" Offset="0.0"/>
        <GradientStop Color="#E6F7F3" Offset="0.5"/>
        <GradientStop Color="#DCF5EF" Offset="1.0"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="SurfaceGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F8FAFC" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- ========== ГРАДИЕНТЫ ДЛЯ КНОПОК ========== -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#2DD4BF" Offset="0.0"/>
        <GradientStop Color="#14B8A6" Offset="1.0"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#2DD4BF" Offset="0.0"/>
        <GradientStop Color="#5EEAD4" Offset="1.0"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="ErrorGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#F59E0B" Offset="0.0"/>
        <GradientStop Color="#FBBF24" Offset="1.0"/>
    </LinearGradientBrush>
    
    <!-- ========== ПОВЕРХНОСТИ ========== -->
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceVariant">#F9FFFD</Color>
    <Color x:Key="SurfaceDark">#F0F7F4</Color>
    
    <!-- ========== ЦВЕТА ТЕКСТА ========== -->
    <Color x:Key="TextPrimary">#0F172A</Color>
    <Color x:Key="TextSecondary">#475569</Color>
    <Color x:Key="TextMuted">#94A3B8</Color>
    <Color x:Key="TextWhite">#FFFFFF</Color>
    
    <!-- ========== СТАТУСЫ ========== -->
    <Color x:Key="Success">#2DD4BF</Color>
    <Color x:Key="SuccessLightBg">#2DD4BF10</Color>
    <Color x:Key="Error">#F59E0B</Color>
    <Color x:Key="ErrorLightBg">#F59E0B10</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="WarningLightBg">#F59E0B10</Color>
    <Color x:Key="Info">#2DD4BF</Color>
    
    <!-- ========== РОЛИ ========== -->
    <Color x:Key="AdminColor">#F59E0B</Color>
    <Color x:Key="TeacherColor">#2DD4BF</Color>
    <Color x:Key="StudentColor">#10B981</Color>
    
    <Color x:Key="ShadowColor">#2DD4BF30</Color>

</ResourceDictionary>